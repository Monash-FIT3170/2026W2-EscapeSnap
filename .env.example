# Copy to `.env` and fill in (never commit real secrets).
# Load in app code via `process.env` only on the server, or use Meteor settings for non-secret config.

# Google Cloud Vision (optional — for photo validation)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# AWS Rekognition (optional — alternative to Vision)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2
